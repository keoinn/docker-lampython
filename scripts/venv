#!/usr/bin/env bash
# 進入 container 並啟用 venv 的互動式 shell
# 用法:
#   ./scripts/venv
#   ./scripts/venv python manage.py migrate

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib.sh"

ensure_container

if [[ $# -eq 0 ]]; then
  docker exec -it -w "$WORKDIR" "$CONTAINER" bash -lc \
    "source ${VENV_DIR}/bin/activate && echo 'venv: ${VENV_DIR}' && echo 'workdir: ${WORKDIR}' && exec bash"
else
  docker exec -it -w "$WORKDIR" "$CONTAINER" bash -lc \
    "source ${VENV_DIR}/bin/activate && exec \"\$@\"" bash "$@"
fi
