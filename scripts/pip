#!/usr/bin/env bash
# 在 container venv 中執行 pip
# 用法:
#   ./scripts/pip install requests
#   ./scripts/pip list

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib.sh"

ensure_container

docker exec -it "$CONTAINER" "$VENV_PIP" "$@"
